{
  "name": "dashboard",
  "version": "1.3.2",
  "private": true,
  "dependencies": {
    "ajv": "^8.17.1",
    "axios": "^1.13.2",
    "bootstrap": "^4.6.2",
    "buffer": "^6.0.3",
    "chart.js": "3.9.1",
    "dayjs": "^1.11.19",
    "font-awesome": "^4.7.0",
    "jalaliday": "^3.1.1",
    "perfect-scrollbar": "1.5.5",
    "process": "^0.11.10",
    "react": "^17.0.2",
    "react-chartjs-2": "3.3.0",
    "react-dom": "^17.0.2",
    "react-icons": "^5.5.0",
    "react-notification-alert": "0.0.13",
    "react-router-dom": "6.11.1",
    "react-scripts": "3.4.1",
    "reactstrap": "^8.4.1",
    "sass": "^1.69.0",
    "sweetalert2": "^11.26.17"
  },
  "scripts": {
    "start": "cross-env HOST=0.0.0.0 PORT=3000 NODE_OPTIONS=--openssl-legacy-provider react-scripts start",
    "build": "cross-env NODE_OPTIONS=--openssl-legacy-provider react-scripts build",
    "test": "cross-env NODE_OPTIONS=--openssl-legacy-provider react-scripts test",
    "eject": "react-scripts eject",
    "install:clean": "rm -rf node_modules/ && rm -rf package-lock.json && npm install && npm start",
    "compile-sass": "node-sass src/assets/scss/paper-dashboard.scss src/assets/css/paper-dashboard.css",
    "minify-sass": "node-sass src/assets/scss/paper-dashboard.scss src/assets/css/paper-dashboard.min.css --output-style compressed",
    "map-sass": "node-sass src/assets/scss/paper-dashboard.scss src/assets/css/paper-dashboard.css --source-map true"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ],
  "optionalDependencies": {
    "typescript": "5.0.4"
  },
  "overrides": {
    "svgo": "3.0.2",
    "fsevents": "2.3.2",
    "chokidar": "3.5.3",
    "@babel/core": "7.18.6"
  },
  "devDependencies": {
    "cross-env": "^10.1.0"
  }
}
